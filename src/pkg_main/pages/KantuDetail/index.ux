<template>
  <div class="page_container">
    <!-- 顶部固定区域 -->
    <div class="top_area">
      <image
        class="top_bg"
        src="/pkg_main/assets/img/wodexunzhang-bg-1.png"
      ></image>

      <!-- 导航�?-->
      <div class="navbar">
        <div class="back_btn" onclick="goBack">
          <image class="back_icon" src="/pkg_main/assets/img/back.png"></image>
        </div>
      </div>

    </div>

    <!-- 序号 Badge -->
    <div class="badge_wrapper">
      <div class="question_header_row">
        <image class="q_icon" src="/pkg_main/assets/img/wenhao.png"></image>
        <text class="question_title_text">{{ quizTitle }}</text>
      </div>
    </div>

    <!-- 主要内容区域 (进度�?+ 题目图片 + 选项) -->
    <div class="content_card">
      <div class="progress_area">
        <text class="progress_text"
          ><span style="color:#ff7500; font-weight:bold;">1</span>/2</text
        >
        <div class="progress_bar_bg">
          <div class="progress_bar_fill"></div>
        </div>
      </div>

      <text class="question_desc">{{ currentQuestion.question }}</text>

      <!-- 题目图片 -->
      <div class="question_img_wrapper">
        <image
          class="question_img"
          src="{{ questionImage }}"
        ></image>
      </div>

      <!-- 选项列表 -->
      <div class="options_list">
        <div
          class="option_item {{selectedOptionIndex === index ? 'option_selected' : ''}}"
          for="{{(index, option) in currentQuestion.options}}"
          onclick="selectOption(index)"
        >
          <text class="option_text">{{ option.label }}.{{ option.text }}</text>
        </div>
      </div>

      <!-- 底部确认按钮 -->
      <div class="confirm_btn_wrapper">
        <div class="confirm_btn" onclick="onConfirm">
          <text class="confirm_text">查看结果</text>
        </div>
      </div>
    </div>

    <!-- 底部导航�?-->
    <div class="tab-bar">
      <div class="tab-item" onclick="goToTab(0)">
        <image class="tab-icon" src="/pkg_main/assets/img/ceping-u.png"></image>
        <text class="tab-text" style="color: #999999">热门测评</text>
      </div>
      <div class="tab-item" onclick="goToTab(1)">
        <image class="tab-icon" src="/pkg_main/assets/img/kantu-s.png"></image>
        <text class="tab-text" style="color: #FFFFFF">看图测评</text>
      </div>
      <div class="tab-item" onclick="goToTab(2)">
        <image
          class="tab-icon"
          src="/pkg_main/assets/img/xinli-u.png"
        ></image>
        <text class="tab-text" style="color: #999999">心理健康</text>
      </div>
      <div class="tab-item" onclick="goToTab(3)">
        <image class="tab-icon" src="/pkg_main/assets/img/mine-u.png"></image>
        <text class="tab-text" style="color: #999999">我的</text>
      </div>
    </div>
  </div>
</template>

<script>
import router from '@system.router'
import prompt from '@system.prompt'
import { imagePersonalityTest } from '../../helper/JS/tupianceshi'

export default {
  data() {
    return {
      id: 0,
      quizTitle: '',
      currentQuestion: {},
      selectedOptionIndex: -1,
      quizItem: null,
      questionImage: ''
    }
  },
  onInit() {
    if (this.$page && this.$page.query && this.$page.query.id) {
      this.id = this.$page.query.id
    }
    console.info('KanTu Detail Page Init, ID:', this.id)
    this.initData()
  },
  initData() {
    const quizId = parseInt(this.id) || 1
    const testList = (imagePersonalityTest && imagePersonalityTest.testList) || []
    this.quizItem = testList.find(item => item.id === quizId)

    if (this.quizItem) {
      this.quizTitle = this.quizItem.name
      const opts = this.quizItem.options || {}
      this.currentQuestion = {
        question: this.quizItem.question,
        options: [
          { label: 'A', text: opts.A || '' },
          { label: 'B', text: opts.B || '' },
          { label: 'C', text: opts.C || '' },
          { label: 'D', text: opts.D || '' }
        ]
      }

      this.questionImage = '/pkg_main/assets/img/ktcp/' + quizId + '.jpg'
    } else {
      if (testList.length > 0) {
        this.quizItem = testList[0]
        this.quizTitle = this.quizItem.name
        const opts = this.quizItem.options || {}
        this.currentQuestion = {
          question: this.quizItem.question,
          options: [
            { label: 'A', text: opts.A || '' },
            { label: 'B', text: opts.B || '' },
            { label: 'C', text: opts.C || '' },
            { label: 'D', text: opts.D || '' }
          ]
        }
        this.id = String(this.quizItem.id)
        this.questionImage = '/pkg_main/assets/img/ktcp/' + this.id + '.jpg'
      }
    }
  },
  goBack() {
    router.back()
  },
  goToTab(index) {
    // 返回主页并切换到指定 tab
    router.replace({
      uri: '/pkg_main/pages/Main',
      params: {
        tabIndex: index
      }
    })
  },
  selectOption(index) {
    this.selectedOptionIndex = index
  },
  onConfirm() {
    if (this.selectedOptionIndex === -1) {
      prompt.showToast({
        message: '请选择一个选项'
      })
      return
    }

    const currentOption = this.currentQuestion.options[this.selectedOptionIndex]
    const label = currentOption.label

    let resultDesc = ''
    if (this.quizItem.conclusion && this.quizItem.conclusion[label]) {
      resultDesc = this.quizItem.conclusion[label]
    }

    if (!resultDesc) {
      resultDesc = '暂无详细结论'
    }

    router.replace({
      uri: '/pkg_main/pages/KantuJielun',
      params: {
        description: resultDesc,
        quizId: this.id,
        quizTitle: this.quizTitle
      }
    })
  }
}
</script>

