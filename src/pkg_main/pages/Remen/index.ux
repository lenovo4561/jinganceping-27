  color: #ffffff;
}

.list-section {
  flex-direction: column;
  width: 100%;
  padding: 10px;
}

.list-item {
  flex-direction: row;
  background-color: #ffffff;
  border-radius: 12px;
  padding: 12px;
  padding-left: 0px;
  padding-right: 5px;
  margin-bottom: 10px;
  align-items: center;
}

.item-img {
  width: 60px;
  height: 60px;
  border-radius: 8px;
  object-fit: cover;
  margin-left: 8px;
}

.item-info {
  flex: 1;
  flex-direction: column;
  margin-left: 12px;
  height: 60px;
  justify-content: space-between;
}

.item-title {
  font-size: 10px;
  color: #333333;
  lines: 1;
  text-overflow: ellipsis;
  margin-top: 4px;
  font-weight: bold;
}

.item-bottom {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

