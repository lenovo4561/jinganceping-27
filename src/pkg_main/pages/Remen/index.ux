<template>
  <div class="page">
    <list class="remen-list">
      <list-item type="header" class="header-section">
        <stack class="header-stack">
          <image class="top-bg" src="../../assets/img/jibu-bg.png"></image>
          <div class="tabs-container">
            <block for="{{tabs}}">
              <div class="{{'tab-item ' + (activeSource === $item.key ? 'active' : '')}}" onclick="switchTab($item.key)">
                <text class="{{'tab-text ' + (activeSource === $item.key ? 'active-text' : '')}}">{{$item.title}}</text>
              </div>
            </block>
          </div>
        </stack>
      </list-item>

      <list-item type="list" class="list-section">
        <block for="{{testList}}">
          <div class="list-item">
            <image class="item-img" src="{{$item.image}}" style="background-color: #eeeeee;"></image>
            <div class="item-info">
              <text class="item-title">{{$item.title}}</text>
              <div class="item-bottom">
                <div class="item-tags">
                  <text class="tag">{{$item.tag}}</text>
                  <text class="tag">自我测评</text>
                </div>
                <div class="btn-box" onclick="startTest($item.id, $item.title)">
                  <text class="start-btn">开始测试</text>
                </div>
              </div>
            </div>
          </div>
        </block>
      </list-item>

      <list-item type="spacer" class="bottom-spacer"></list-item>
    </list>
  </div>
</template>

<script>
import router from '@system.router'
import { getRemenTabs, getRemenListBySource } from '../../helper/JS/remenDataAdapter'

export default {
  data() {
    return {
      activeSource: 'xingge',
      tabs: getRemenTabs(),
      testList: []
    }
  },
  onInit() {
    this.refreshList()
  },
  refreshList() {
    this.testList = getRemenListBySource(this.activeSource)
  },
  switchTab(source) {
    if (!source || source === this.activeSource) return
    this.activeSource = source
    this.refreshList()
  },
  startTest(testId, testName) {
    router.push({
      uri: '/pkg_main/pages/RemenDati',
      params: {
        catTitle: this.activeSource,
        testName: testName,
        testSource: this.activeSource,
        testId: String(testId)
      }
    })
  }
}
</script>

