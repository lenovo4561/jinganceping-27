  flex: 1;
}

/* 结论面板 */
.frosted-panel {
  flex: 1;
  flex-direction: column;
  width: 230px;
  margin-top: -48px;
  margin-left: 10px;
  margin-right: 10px;
  border-radius: 16px;
  background-color: transparent;
  position: relative;
  overflow: hidden;
}
.blur-layer {
  display: none;
}
.frost-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 230px;
  height: 100%;
  border-radius: 16px;
  background: linear-gradient(
    to bottom,
    rgba(255, 255, 255, 0.60) 0%,
    rgba(255, 255, 255, 1.0) 15%,
    rgba(255, 255, 255, 1.0) 100%
  );
}
.panel-content {
  flex: 1;
  flex-direction: column;
  position: relative;
  z-index: 1;
  padding: 20px 16px 0 16px;
}

/* 结论 tag */
.result-title-container {
  flex-direction: column;
  margin-bottom: 20px;
}
.result-main-title {
  font-size: 14px;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8px;
}
